# Copy this file to .env and fill in your values.
# .env is git-ignored — NEVER commit .env with real credentials.

# Backend
VITE_API_URL=http://localhost:8080/api

# Mapbox — account.mapbox.com → Tokens
VITE_MAPBOX_TOKEN=

# Strava
VITE_STRAVA_CLIENT_ID=

# Stripe — dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLIC_KEY=pk_test_...
VITE_STRIPE_PRICE_PREMIUM_MONTHLY=price_...
VITE_STRIPE_PRICE_PREMIUM_ANNUAL=price_...
VITE_STRIPE_PRICE_DUO_MONTHLY=price_...
VITE_STRIPE_PRICE_DUO_ANNUAL=price_...
