      "source": "composite",
      "source-layer": "road",
      "minzoom": 12,
      "filter": ["has", "name"],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 9, 18, 13],
        "text-rotation-alignment": "map",
        "text-pitch-alignment": "viewport",
        "text-max-angle": 30
