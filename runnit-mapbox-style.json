      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#FFFFFF"
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["residential", "suburb", "neighbourhood"], true, false],
      "paint": {
        "fill-color": "#F5F5F5",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landuse-commercial",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["commercial", "industrial"], true, false],
      "paint": {
        "fill-color": "#F0F0F0",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["park", "grass", "recreation_ground", "garden", "playground", "pitch", "cemetery", "wood"], true, false],
      "paint": {
        "fill-color": "#EBF2EB",
        "fill-opacity": 1
      }
    },
    {
      "id": "landuse-overlay-protected",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse_overlay",
      "filter": ["match", ["get", "class"], ["national_park", "nature_reserve", "nature"], true, false],
      "paint": {
        "fill-color": "#E2EDE2",
        "fill-opacity": 0.75
      }
    },
    {
