      "source": "composite",
      "source-layer": "road",
      "filter": ["==", ["get", "class"], "motorway"],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#1A1A1A",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.75, 14, 7, 18, 20]
      }
    },
    {
      "id": "admin-state",
      "type": "line",
      "source": "composite",
