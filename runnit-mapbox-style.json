      "type": "fill",
      "source": "composite",
      "source-layer": "building",
      "minzoom": 15,
      "paint": {
        "fill-color": "#EBEBEB",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 1]
      }
