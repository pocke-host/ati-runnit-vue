        "text-halo-color": "#FFFFFF",
        "text-halo-width": 2,
        "text-halo-blur": 0.5
      }
    },
    {
      "id": "place-state",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "minzoom": 5,
      "maxzoom": 10,
      "filter": ["==", ["get", "class"], "state"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 10, 9, 16],
