      "type": "fill",
      "source": "composite",
      "source-layer": "hillshade",
      "paint": {
        "fill-antialias": false,
        "fill-color": [
          "match", ["get", "level"],
          89, "#FFFFFF",
          78, "#F4F4F4",
          67, "#EBEBEB",
          56, "#E2E2E2",
          22, "#D5D5D5",
          11, "#C8C8C8",
          "#FFFFFF"
        ],
        "fill-opacity": 0.4
      }
    },
    {
      "id": "contour",
      "type": "line",
      "source": "composite",
      "source-layer": "contour",
      "minzoom": 11,
      "paint": {
        "line-color": "#DEDEDE",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.4, 16, 0.8],
        "line-opacity": 0.55
      }
    },
    {
      "id": "contour-index",
      "type": "line",
      "source": "composite",
      "source-layer": "contour",
      "minzoom": 11,
      "filter": ["match", ["get", "index"], [5, 10], true, false],
      "paint": {
        "line-color": "#C8C8C8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.6, 16, 1.2],
        "line-opacity": 0.65
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "composite",
